{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@avaluz/ui": [
        "./packages/ui/index.ts"
      ],
      "@avaluz/ui/*": [
        "./packages/ui/*"
      ],
      "@avaluz/lib": [
        "./packages/lib/index.ts"
      ],
      "@avaluz/lib/*": [
        "./packages/lib/*"
      ],
      "@avaluz/types": [
        "./packages/types/index.ts"
      ],
      "@avaluz/types/*": [
        "./packages/types/*"
      ],
      "@avaluz/api": [
        "./packages/api/index.ts"
      ],
      "@avaluz/api/*": [
        "./packages/api/*"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": [
    "src",
    "packages"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ]
}